# Copy to .env and fill in. .env is gitignored.
DEEPSEEK_API_KEY=
# Persisted store for decisions + the audit trail, behind one DATABASE_URL seam.
# Defaults to a SQLite file (backend/data/app.db) — zero-ops for the demo. Uncomment to
# run on a production RDBMS with no code change (see docker-compose.yml for local Postgres):
# DATABASE_URL=postgresql+psycopg://aml:aml@localhost:5432/aml
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MODEL_WORKHORSE=deepseek-v4-pro
MODEL_VERIFIER=deepseek-v4-flash
# LLM client resilience for the live /triage run.
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
# Longer timeout for offline build tools (precompute, eval) so a valid slow
# reasoning call isn't aborted + retried mid-batch.
OFFLINE_LLM_TIMEOUT_SECONDS=180
# Verifier flag / triage forces human review below this confidence (ADR-0007).
REVIEW_THRESHOLD=0.6
# Queue Agent auto-clears a verifier-agreed dismiss only at/above this confidence
# (ADR-0010). Must stay strictly above REVIEW_THRESHOLD.
AUTO_CLEAR_THRESHOLD=0.85
RANDOM_SEED=42
