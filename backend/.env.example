# Copy to .env and fill in. .env is gitignored.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MODEL_WORKHORSE=deepseek-v4-pro
MODEL_VERIFIER=deepseek-v4-flash
# LLM client resilience for the live /triage run.
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
REVIEW_THRESHOLD=0.6
RANDOM_SEED=42
